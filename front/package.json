{
  "name": "front",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "build-only": "vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --build",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "api:types": "openapi-typescript ../tsp-output/openapi.yaml -o ./src/types/api.d.ts",
    "mock": "prism mock ../tsp-output/openapi.yaml --port 4010",
    "mock:proxy": "prism proxy ../tsp-output/openapi.yaml http://localhost:3000 --port 4010"
  },
  "dependencies": {
    "@pinia/colada": "^1.2.0",
    "@vuetify/v0": "^1.0.0-alpha.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@stoplight/prism-cli": "^5.14.2",
    "@tailwindcss/vite": "^4.2.4",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/ui": "^4.1.5",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.1",
    "eslint-plugin-format": "^2.0.1",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.2",
    "npm-run-all2": "^8.0.4",
    "openapi-typescript": "^7.13.0",
    "tailwindcss": "^4.2.4",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.7"
  }
}
